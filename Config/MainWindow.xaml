                                            ToolTip="The total vertical size for your third pocket slot."
                                        />
                                    </DockPanel>
                                    <DockPanel Margin="4,3">
                                        <TextBlock
                                            Style="{StaticResource SmallFieldLabel}"
                                            Text="Pocket 3 Horizontal"
                                            ToolTip="The total horizontal size for your third pocket slot."
                                        />
