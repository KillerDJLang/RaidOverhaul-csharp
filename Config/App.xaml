<Application x:Class="ROConfig.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ROConfig"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <SolidColorBrush x:Key="WindowBg"       Color="#1C1C1C"/>
        <SolidColorBrush x:Key="PanelBg"        Color="#252525"/>
        <SolidColorBrush x:Key="GroupBg"        Color="#2A2A2A"/>
        <SolidColorBrush x:Key="AccentGold"     Color="#C4A46B"/>
        <SolidColorBrush x:Key="TextLight"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextDim"        Color="#AAAAAA"/>
        <SolidColorBrush x:Key="InputBg"        Color="#333333"/>
        <SolidColorBrush x:Key="InputBorder"    Color="#555555"/>
        <SolidColorBrush x:Key="SaveColor"      Color="#008080"/>
        <SolidColorBrush x:Key="RevertColor"    Color="#800000"/>
        <SolidColorBrush x:Key="SavedFg"        Color="#7CFC00"/>
        <SolidColorBrush x:Key="RevertedFg"     Color="#CC4444"/>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground"       Value="{StaticResource AccentGold}"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="BorderBrush"      Value="#555555"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="Background"       Value="{StaticResource GroupBg}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="4,4"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource InputBorder}"/>
            <Setter Property="CaretBrush"       Value="White"/>
            <Setter Property="Padding"          Value="4,2"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource AccentGold}"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,8,0,4"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"         Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Width"              Value="220"/>
        </Style>

        <Style x:Key="SmallFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"         Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Width"              Value="160"/>
        </Style>

        <Style x:Key="NumericBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width"   Value="85"/>
            <Setter Property="Margin"  Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource SaveColor}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Padding"     Value="20,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="RevertBtn" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource RevertColor}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Padding"     Value="20,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground"  Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Background"  Value="#222222"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background"    Value="{StaticResource WindowBg}"/>
            <Setter Property="BorderBrush"   Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Application.Resources>
</Application>
